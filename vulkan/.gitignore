# Build output
build/
_build*/

# Compiled SPIR-V binaries (regenerated by the build system)
*.spv

# macOS Finder metadata
.DS_Store

# CMake user-local preset overrides (machine-specific, never shared)
CMakeUserPresets.json

# clangd / compile_commands (generated by CMake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON)
compile_commands.json

# macOS debug symbol bundles (produced by the linker in Debug builds)
*.dSYM/
